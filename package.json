{
  "name": "campus-notification-system",
  "private": true,
  "type": "module",
  "scripts": {
    "stage1": "node --env-file=.env notification_app_be/src/index.ts",
    "frontend:dev": "npm --prefix notification_app_fe run dev",
    "frontend:build": "npm --prefix notification_app_fe run build",
    "frontend:preview": "npm --prefix notification_app_fe run preview",
